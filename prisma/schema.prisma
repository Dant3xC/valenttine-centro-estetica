generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id                   Int           @id @default(autoincrement())
  username             String        @unique @db.VarChar(11)
  contraseña          String        @db.VarChar(72)
  rolId                Int
  email                String        @unique
  creadoEn             DateTime      @default(now())
  actualizadoEn        DateTime      @updatedAt
  pacientesCreados     Paciente[]    @relation("PacienteCreadoPor")
  paciente             Paciente?     @relation("PacienteUsuario")
  profesionalesCreados Profesional[] @relation("ProfesionalCreadoPor")
  profesional          Profesional?  @relation("ProfesionalUsuario")
  Rol                  Rol           @relation(fields: [rolId], references: [id])
}

model Provincia {
  id            Int           @id @default(autoincrement())
  nombre        String        @unique
  localidades   Localidad[]
  pacientes     Paciente[]
  profesionales Profesional[]
}

model Localidad {
  id            Int           @id @default(autoincrement())
  nombre        String
  provinciaId   Int
  provincia     Provincia     @relation(fields: [provinciaId], references: [id])
  pacientes     Paciente[]
  profesionales Profesional[]
}

model ObraSocial {
  id            Int                      @id @default(autoincrement())
  nombre        String                   @unique
  profesionales ObraSocialXProfesional[]
  pacientes     Paciente[]
}

model Prestacion {
  id            Int                      @id @default(autoincrement())
  nombre        String
  descripcion   String?
  profesionales PrestacionXProfesional[]
}

model Paciente {
  id              Int               @id @default(autoincrement())
  userId          Int               @unique
  creadoPorId     Int?
  numeroInterno   String            @unique
  nombre          String
  apellido        String
  dni             String            @db.VarChar(8)
  fechaNacimiento DateTime
  generoId        Int
  estadoCivilId   Int
  pais            String
  provinciaId     Int
  localidadId     Int
  barrio          String?
  calle           String
  numero          String
  celular         String            @db.VarChar(15)
  email           String
  obraSocialId    Int
  numeroSocio     String
  plan            String
  estado          Int
  creadoEn        DateTime          @default(now())
  actualizadoEn   DateTime          @updatedAt
  HistoriaClinica HistoriaClinica[]
  creadoPor       Usuario?          @relation("PacienteCreadoPor", fields: [creadoPorId], references: [id])
  EstadoCivil     EstadoCivil       @relation(fields: [estadoCivilId], references: [id])
  EstadoPaciente  EstadoPaciente    @relation(fields: [estado], references: [id])
  Genero          Genero            @relation(fields: [generoId], references: [id])
  localidad       Localidad         @relation(fields: [localidadId], references: [id])
  obraSocial      ObraSocial        @relation(fields: [obraSocialId], references: [id])
  provincia       Provincia         @relation(fields: [provinciaId], references: [id])
  usuario         Usuario           @relation("PacienteUsuario", fields: [userId], references: [id])
  turnos          Turno[]
}

model Profesional {
  id              Int                      @id @default(autoincrement())
  userId          Int                      @unique
  creadoPorId     Int?
  numeroInterno   String                   @unique
  nombre          String
  apellido        String
  dni             String                   @db.VarChar(8)
  fechaNacimiento DateTime
  generoId        Int
  estadoCivilId   Int
  pais            String
  provinciaId     Int
  localidadId     Int
  barrio          String?
  calle           String
  numero          String
  celular         String                   @db.VarChar(15)
  email           String                   @unique
  titulo          String
  matricula       String                   @unique
  especialidad    String
  universidad     String
  fechaGraduacion DateTime
  horarioTrabajo  String
  creadoEn        DateTime                 @default(now())
  actualizadoEn   DateTime                 @updatedAt
  fotoPath        String?
  HistoriaClinica HistoriaClinica[]
  obrasSociales   ObraSocialXProfesional[]
  prestaciones    PrestacionXProfesional[]
  creadoPor       Usuario?                 @relation("ProfesionalCreadoPor", fields: [creadoPorId], references: [id])
  EstadoCivil     EstadoCivil              @relation(fields: [estadoCivilId], references: [id])
  Genero          Genero                   @relation(fields: [generoId], references: [id])
  localidad       Localidad                @relation(fields: [localidadId], references: [id])
  provincia       Provincia                @relation(fields: [provinciaId], references: [id])
  usuario         Usuario                  @relation("ProfesionalUsuario", fields: [userId], references: [id])
  turnos          Turno[]
}

model PrestacionXProfesional {
  id            Int         @id @default(autoincrement())
  profesionalId Int
  prestacionId  Int
  prestacion    Prestacion  @relation(fields: [prestacionId], references: [id])
  profesional   Profesional @relation(fields: [profesionalId], references: [id])
}

model ObraSocialXProfesional {
  id            Int         @id @default(autoincrement())
  profesionalId Int
  obraSocialId  Int
  obraSocial    ObraSocial  @relation(fields: [obraSocialId], references: [id])
  profesional   Profesional @relation(fields: [profesionalId], references: [id])
}

model Turno {
  id            Int            @id @default(autoincrement())
  pacienteId    Int
  profesionalId Int
  fecha         DateTime
  hora          String
  estadoId      Int
  creadoEn      DateTime       @default(now())
  Consulta      Consulta[]
  detalles      DetalleTurno[]
  EstadoTurno   EstadoTurno    @relation(fields: [estadoId], references: [id])
  paciente      Paciente       @relation(fields: [pacienteId], references: [id])
  profesional   Profesional    @relation(fields: [profesionalId], references: [id])
}

model DetalleTurno {
  id          Int      @id @default(autoincrement())
  turnoId     Int
  descripcion String
  observacion String?
  creadoEn    DateTime @default(now())
  turno       Turno    @relation(fields: [turnoId], references: [id])
}

model CentroMedico {
  id        Int    @id @default(autoincrement())
  nombre    String
  direccion String
  telefono  String
  email     String
}

model Anamnesis {
  id                Int             @id @default(autoincrement())
  historiaClinicaId Int             @unique
  fuma              Int
  alcohol           String?
  dieta             String?
  agua              Int
  HistoriaClinica   HistoriaClinica @relation(fields: [historiaClinicaId], references: [id])
  Antecedente       Antecedente[]
}

model Antecedente {
  id          Int       @id @default(autoincrement())
  anamnesisId Int
  tipo        String
  nombre      String
  detalle     String?
  desde       DateTime?
  estado      String?
  categoria   String?
  Anamnesis   Anamnesis @relation(fields: [anamnesisId], references: [id])
}

model Consulta {
  id                Int              @id @default(autoincrement())
  historiaClinicaId Int
  turnoId           Int?
  derivacion        Boolean          @default(false)
  profesionalDeriva String?
  motivoDerivacion  String?
  documentacion     String?
  fecha             DateTime         @default(now())
  tipoConsulta      String?
  observaciones     String?
  motivoConsulta         String?
  evolucion              String?
  comparacion            String?
  tratamientosRealizados Json?
  productosUtilizados    Json?
  usoAnestesia           Boolean?
  toleranciaPaciente     String?
  medicacionPrescrita    String?
  HistoriaClinica   HistoriaClinica  @relation(fields: [historiaClinicaId], references: [id])
  Turno             Turno?           @relation(fields: [turnoId], references: [id])
}

model Diagnostico {
  id                  Int             @id @default(autoincrement())
  historiaClinicaId   Int             @unique
  observacion         String?
  descripcionFacial   Json?
  descripcionCorporal Json?
  descripcionCapilar  Json?
  HistoriaClinica     HistoriaClinica @relation(fields: [historiaClinicaId], references: [id])
}

model EstadoCivil {
  id          Int           @id @default(autoincrement())
  nombre      String        @unique
  Paciente    Paciente[]
  Profesional Profesional[]
}

model EstadoPaciente {
  id       Int        @id @default(autoincrement())
  nombre   String     @unique
  Paciente Paciente[]
}

model EstadoTurno {
  id     Int     @id @default(autoincrement())
  nombre String  @unique
  Turno  Turno[]
}

model Genero {
  id          Int           @id @default(autoincrement())
  nombre      String        @unique
  Paciente    Paciente[]
  Profesional Profesional[]
}

model HistoriaClinica {
  id            Int          @id @default(autoincrement())
  pacienteId    Int
  profesionalId Int
  fechaApertura DateTime     @default(now())
  motivoInicial String?
  observaciones String?
  estado        Boolean      @default(true)
  Anamnesis     Anamnesis?
  Consulta      Consulta[]
  Diagnostico   Diagnostico?
  PlanTratamiento PlanTratamiento?
  Paciente      Paciente     @relation(fields: [pacienteId], references: [id])
  Profesional   Profesional  @relation(fields: [profesionalId], references: [id])
}

model PlanTratamiento {
  id                     Int      @id @default(autoincrement())
  // consultaId             Int?    @unique
  historiaClinicaId      Int?    @unique
  objetivo               String?
  frecuencia             String? //
  sesionesTotales        Int?  //
  indicacionesPost       String? //
  resultadosEsperados    String?
  estado                 Boolean  @default(true)
  observaciones          String?
  // Consulta               Consulta? @relation(fields: [consultaId], references: [id], onDelete: SetNull)
  historiaClinica         HistoriaClinica? @relation(fields: [historiaClinicaId], references: [id])
}

model Rol {
  id      Int       @id @default(autoincrement())
  nombre  String    @unique
  Usuario Usuario[]
}

